# GCP project hosting the data (BigQuery, GCS)
GCP_PROJECT=
# GCP project hosting compute resources and Secret Manager (defaults to GCP_PROJECT if unset)
GCP_COMPUTE_PROJECT=
# Region for Compute Engine / Cloud Run
GCP_REGION=
# BigQuery location (e.g. EU, US)
BQ_REGION=
# BigQuery dataset containing the raw sensor table
BQ_DATASET=
# BigQuery table with raw methane sensor readings
BQ_TABLE=
# BigQuery dataset for output tables (predictions, history). Defaults to BQ_DATASET if unset.
BQ_OUTPUT_DATASET=
# GCS bucket for models and preprocessing artifacts
BUCKET_NAME=
